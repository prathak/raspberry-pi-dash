[Unit]
Description=Magic Mirror Dashboard
After=network.target

[Service]
Type=simple
User=pg
WorkingDirectory=/home/pg/raspberry-pi-dash
ExecStartPre=/usr/bin/pkill -f 'chromium.*localhost:3000' ; true
ExecStart=/usr/bin/npm run start -- -p 3000
ExecStartPost=/home/pg/raspberry-pi-dash/start-kiosk.sh
Restart=always
RestartSec=10
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target